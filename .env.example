# FlyFam — Environment Variables
# Copy to .env and fill in your values

# Supabase (from project Settings > API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key


# Supabase Service Role (for Edge Functions / backend only — never expose in client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Aynı anahtar: scripts/flight-provider-snapshot-report.js → PDF/DB sütunu için `flights` REST okuması (yerel rapor)

# Aviation Stack (flight status API)
# https://aviationstack.com/
AVIATION_STACK_API_KEY=your-aviation-stack-key

# AirLabs Data API v9 (flight info, schedules, live flights — https://airlabs.co/docs)
# AIRLABS_API_KEY=your-airlabs-key
# Mobile: EXPO_PUBLIC_AIRLABS_API_KEY=... (only if needed in app; prefer server-side)
# AeroDataBox
# Primary (RapidAPI): AERODATABOX_RAPIDAPI_KEY
# Secondary (API Market fallback): AERODATABOX_APIMARKET_BASE + AERODATABOX_APIMARKET_KEY
# AERODATABOX_RAPIDAPI_KEY=your-adb-rapidapi-key
# AERODATABOX_APIMARKET_BASE=https://your-apimarket-base-url
# AERODATABOX_APIMARKET_KEY=your-adb-apimarket-key

# Flightradar24 API (flight status + airports sync script)
# EXPO_PUBLIC_FLIGHTRADAR24_API_TOKEN=your-fr24-token
# For scripts/sync-fr24-airports.js also set SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY (or use .env)
# Flightradar24 — Supabase Edge secrets (Dashboard → Edge Functions → Secrets)
# Uçuş edge’leri zaten şunu kullanıyor; ekstra secret açmana gerek yok:
#   FR24_API_TOKEN=<Flightradar24 API bearer token>
# sync-fr24-usage-metrics ve admin-dashboard da aynı FR24_API_TOKEN ile FR24 çağırır (FR24API_TOKEN yedek isimdir).
# URL secret’ları ZORUNLU DEĞİL: varsayılan https://fr24api.flightradar24.com/api/usage (Bearer + Accept-Version v1 function içinde).
# FR24 usage metrics history sync (Edge: sync-fr24-usage-metrics) — isteğe bağlı override’lar:
# FR24_USAGE_METRICS_URL=https://fr24api.flightradar24.com/api/usage
# ADMIN_FR24_USAGE_URL=https://fr24api.flightradar24.com/api/usage
# FR24_USAGE_METRICS_PERIOD=30d
# FR24_USAGE_AUTH_BEARER=...   # only if you do not use FR24_API_TOKEN
# FR24API_TOKEN=...            # alias; prefer FR24_API_TOKEN
# OR
# FR24_USAGE_BASIC_USER=your-login
# FR24_USAGE_BASIC_PASS=your-password
# Optional (if portal requires cookie/session):
# FR24_USAGE_COOKIE=your-cookie-string
# Optional custom headers JSON:
# FR24_USAGE_EXTRA_HEADERS_JSON={"x-api-key":"...","User-Agent":"Mozilla/5.0"}

# FlightAPI (https://docs.flightapi.io/) — uçuş takibi + havalimanı programı; Edge secret veya mobil .env
# FLIGHTAPI_API_KEY=your-flightapi-key
# EXPO_PUBLIC_FLIGHTAPI_API_KEY=your-flightapi-key

# Expo Push (optional — for sending pushes from backend)
# EXPO_ACCESS_TOKEN=your-expo-token
