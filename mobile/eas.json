{
  "cli": { "version": ">= 12.0.0" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": true }
    },
    "preview": {
      "distribution": "internal",
      "ios": { "simulator": false },
      "env": { "APP_ENV": "preview" }
    },
    "production": {
      "distribution": "store",
      "ios": { "resourceClass": "m-medium", "autoIncrement": true },
      "env": { "APP_ENV": "production" }
    }
  }
}
