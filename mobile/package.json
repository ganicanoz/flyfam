{
  "name": "flyfam-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo start --ios --clear",
    "web": "expo start --web",
    "ios:sim": "REACT_NATIVE_PACKAGER_HOSTNAME=127.0.0.1 npx expo start --ios --clear",
    "clean": "rm -rf node_modules/.cache .expo /tmp/metro-* /tmp/haste-* 2>/dev/null; echo 'Cache cleared. Run: npm run ios:sim'"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/bottom-tabs": "^7.13.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "@supabase/supabase-js": "^2.45.0",
    "expo": "~54.0.0",
    "expo-asset": "~11.0.0",
    "expo-constants": "~17.0.3",
    "expo-device": "^8.0.10",
    "expo-linking": "~7.0.0",
    "expo-notifications": "^0.32.16",
    "expo-secure-store": "~14.0.0",
    "expo-splash-screen": "~0.29.0",
    "expo-status-bar": "~2.0.0",
    "react": "19.1.0",
    "react-native": "0.81.1",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.10.0",
    "web-streams-polyfill": "^3.2.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.2.0",
    "typescript": "~5.3.0"
  },
  "overrides": {
    "minimatch": "^10.2.1"
  },
  "private": true
}
