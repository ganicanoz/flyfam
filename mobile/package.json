{
  "name": "flyfam-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test-api": "node scripts/test-flight-api.js",
    "start": "expo start",
    "start:clear": "expo start --clear",
    "android": "expo run:android",
    "ios": "expo start --ios --clear",
    "web": "expo start --web",
    "ios:sim": "REACT_NATIVE_PACKAGER_HOSTNAME=127.0.0.1 npx expo start --ios --clear",
    "clean": "rm -rf node_modules/.cache .expo /tmp/metro-* /tmp/haste-* 2>/dev/null; echo 'Cache cleared. Run: npm run ios:sim'",
    "build:ios": "npx eas-cli@latest build --profile preview --platform ios --non-interactive",
    "build:ios:sim": "npx eas-cli@latest build --profile development --platform ios --non-interactive",
    "build:ios:store": "npx eas-cli@latest build --profile production --platform ios --non-interactive",
    "build:android": "npx eas-cli@latest build --profile preview --platform android --non-interactive",
    "submit:ios": "npx eas-cli@latest submit --platform ios --latest --profile production --non-interactive",
    "doctor": "expo-doctor"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.13.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "@supabase/supabase-js": "^2.45.0",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.12",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-device": "^8.0.10",
    "expo-linking": "~8.0.11",
    "expo-notifications": "^0.32.16",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "i18next": "^25.8.13",
    "react": "19.1.0",
    "react-i18next": "^16.5.4",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "web-streams-polyfill": "^3.2.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "@expo/config-plugins": "~9.0.0",
    "@expo/prebuild-config": "~8.0.0"
  },
  "private": true
}
